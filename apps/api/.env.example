# Port the API listens on (default 3001)
PORT=3001

# Postgres connection string for live data (omit to use fixtures only)
# DATABASE_URL=postgresql://varatrace:varatrace@localhost:5432/varatrace

# Vara endpoint used only when payload metadata is not available in fixtures or Postgres.
VARA_WSS=wss://testnet.vara.network

# Optional bounded indexer backfill window. Used by the indexer, documented here
# because production API/indexer usually share the same managed Postgres.
# FROM_BLOCK=28000000
# TO_BLOCK=28001000
