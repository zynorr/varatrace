# WebSocket endpoint for the Vara network (testnet by default)
VARA_WSS=wss://testnet.vara.network

# Postgres connection string used by the indexer and API in live mode.
DATABASE_URL=postgresql://varatrace:varatrace@localhost:5432/varatrace

# Optional historical backfill start block. Omit to subscribe from latest only.
# FROM_BLOCK=28000000

# Optional inclusive historical backfill end block for targeted scans.
# TO_BLOCK=28001000

# Cache program metadata in Postgres so the API can decode payloads offline.
# FETCH_METADATA=true
